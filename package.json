{
  "name": "jobwatch",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test 'test/*.test.mjs'",
    "sync": "node scripts/sync.mjs",
    "probe": "node scripts/probe.mjs",
    "budget": "node scripts/budget.mjs",
    "check": "node scripts/sync.mjs && node scripts/probe.mjs && node --test 'test/*.test.mjs'",
    "sync:mech": "node scripts/sync.mjs mech",
    "probe:mech": "PROFILE=mech node scripts/probe.mjs",
    "check:mech": "node scripts/sync.mjs mech && PROFILE=mech node scripts/probe.mjs && node --test 'test/*.test.mjs'"
  }
}
